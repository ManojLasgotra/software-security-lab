<!DOCTYPE html>
<html>
<body>

<h2>Vulnerable XSS</h2>

<input type="text" id="name">
<button onclick="show()">Submit</button>

<p id="output"></p>

<script>
function show() {
    var input = document.getElementById("name").value;
    document.getElementById("output").innerHTML = input; // ❌ vulnerable
}
</script>

<hr>

<h2>Secure XSS</h2>

<input type="text" id="safeName">
<button onclick="safeShow()">Submit</button>

<p id="safeOutput"></p>

<script>
function safeShow() {
    var input = document.getElementById("safeName").value;
    document.getElementById("safeOutput").innerText = input; // ✅ safe
}
</script>

</body>
</html>
